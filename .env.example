# ══════════════════════════════════════════════════════════════════════════════
# WorkDaemon environment — COMPLETE surface used by api/ + scripts/.
# Vercel prod/preview env must mirror the non-VITE vars; the frontend only sees
# VITE_-prefixed ones. Blank = optional (feature degrades gracefully unless noted).
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (server-side API routes) — REQUIRED ──────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase (frontend — Vite needs VITE_ prefix) — REQUIRED ──────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Direct Postgres (migrations / seed scripts ONLY — this IS the prod DB) ────
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=https://app.workdaemon.com
PUBLIC_BASE_URL=            # public base for unsubscribe/links (agents email)
OAUTH_REDIRECT_BASE=        # override OAuth callback base (else derived from request)

# ── Security — REQUIRED IN PROD (signing/encryption FAIL CLOSED without these) ─
ENCRYPTION_KEY=             # openssl rand -hex 32 — AES-256-GCM for stored API keys
SERVICE_TOKEN_SECRET=       # HMAC for per-company brain-MCP service tokens
OAUTH_STATE_SECRET=         # HMAC for OAuth state (falls back to ENCRYPTION_KEY)
CRON_SECRET=                # Vercel Cron Authorization bearer for scan_external/run_due

# ── Rate limiting (Upstash REST; in-memory per-instance fallback if unset) ────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── AI providers (env fallback chain when a workspace has no key of its own) ──
# chat.js order: HERMES_SHARED_* → DEEPSEEK → ANTHROPIC → OPENAI (else 503).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=          # default https://api.deepseek.com
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Shared Hermes gateway = platform-default daemon for keyless workspaces.
HERMES_SHARED_GATEWAY_URL=
HERMES_SHARED_API_KEY=
HERMES_SHARED_MODEL=

# ── Brain routing / scan tuning (all optional, sane defaults in code) ─────────
BRAIN_TWO_TIER=             # 'off' forces fast-only
BRAIN_FAST_MODEL=
BRAIN_DEEP_MODEL=
BRAIN_REASONING_EFFORT=     # low|medium|high (reasoner models only)
CHAT_LLM_TIMEOUT_MS=        # per-LLM-call wall clock, default 24000
BRAIN_SCAN_BATCH=           # workspaces per cron run, default 25
BRAIN_SCAN_BUDGET_MS=       # cron wall-clock budget, default 50000
BRAIN_ACTIVE_WINDOW_DAYS=   # skip-inactive window, default 14
BRAIN_DEEP_PER_RUN=         # deep passes per cron run, default 1
BRAIN_DEEP_TIMEOUT_MS=      # deep pass timeout, default 30000
BRAIN_SIGNAL_RETENTION_DAYS=# learning_signals retention, default 90
AGENTS_RUN_BATCH=           # agents per run_due cron, default in code
AGENTS_RUN_BUDGET_MS=

# ── Web research ──────────────────────────────────────────────────────────────
TAVILY_API_KEY=             # preferred: search + page reading
BRAVE_SEARCH_API_KEY=       # fallback search

# ── EMBEDDINGS (platform-managed — customers connect only a reasoning key) ────
# If unset / unreachable, retrieval falls back to keyword (KB still works).
EMBEDDINGS_PROVIDER=modal   # modal | ollama | openai | mistral
MODAL_EMBEDDINGS_URL=       # from `modal deploy finetuning/modal/embeddings_app.py`
MODAL_SERVE_SECRET=         # bearer; == the SERVE_MASTER_SECRET Modal secret
EMBEDDINGS_MODEL=nomic-embed-text   # 768-dim (matches the vector column)
EMBEDDINGS_API_KEY=         # central platform key for hosted providers
EMBEDDINGS_BASE_URL=        # ollama base when PROVIDER=ollama
EMBEDDINGS_OPENAI_BASE_URL= # any OpenAI-compatible embeddings base
EMBED_TIMEOUT_MS=           # default 7000 (covers Modal cold start)
# NOTE: changing embedding dimension requires altering workspace_documents.embedding
#       vector(N) + match_documents, then reindex. nomic=768, openai-3-small=1536.

# ── Tool OAuth (per provider; unset = that integration hidden/disabled) ───────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=       # Events API signature verification
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# Agent outbound channels (P2)
X_CLIENT_ID=
LINKEDIN_CLIENT_ID=

# ── Agents email channel (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=                 # or SENDER_ADDRESS / SENDER_NAME below
SENDER_ADDRESS=
SENDER_NAME=

# ── Brain-as-MCP (legacy single-workspace token; new flow uses signed tokens) ──
BRAIN_MCP_TOKEN=
BRAIN_MCP_WORKSPACE_ID=

# ── Misc ──────────────────────────────────────────────────────────────────────
GITHUB_REPO=                # owner/repo for codebase-improver issue filing
WORKDAEMON_WORKSPACE_ID=    # WorkDaemon HQ workspace (code-proposal inbox)
NEXT_PUBLIC_SUPABASE_URL=   # legacy alias some scripts accept for SUPABASE_URL
