# ── Supabase (server-side API routes) ────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Supabase (frontend — Vite needs VITE_ prefix) ─────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://workdaemon-prod.vercel.app

# ── AI (optional — enables server-side /api/chat) ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── EMBEDDINGS (platform-managed — customers connect only a reasoning key) ──────
# The knowledge-base search embedder. Configured ONCE here, shared by all workspaces.
# Switching platforms = change these vars + run a re-index (POST /api/brain {action:"reindex"}).
# If unset / unreachable, retrieval falls back to keyword (KB still works).
EMBEDDINGS_PROVIDER=modal              # modal | ollama | openai | mistral
# -- our infra (default): Modal-served Ollama (nomic-embed-text, 768-dim) --
MODAL_EMBEDDINGS_URL=                   # full endpoint from `modal deploy finetuning/modal/embeddings_app.py`
MODAL_SERVE_SECRET=                     # bearer; == the SERVE_MASTER_SECRET Modal secret
EMBEDDINGS_MODEL=nomic-embed-text       # 768-dim (matches the vector column)
# -- or a hosted OpenAI-compatible key (set PROVIDER=openai|mistral) --
EMBEDDINGS_API_KEY=                     # central platform key (NOT a customer key)
EMBEDDINGS_OPENAI_BASE_URL=             # optional: any OpenAI-compatible embeddings base (Together/Voyage/vLLM/…)
# NOTE: changing the model's dimension requires altering workspace_documents.embedding
#       vector(N) + match_documents to match, then reindex. nomic=768, openai-3-small=1536.

# ── SENSITIVE TIER (keep queries on our own infra) ──────────────────────────────
# Sensitive reasoning routes to a private LLM we run (Modal-served per-company model,
# or a VPS/Ollama box) instead of a hosted API. Point a workspace's `modal` provider
# key at this serving base, or set a default here.
SENSITIVE_SERVE_URL=                    # base URL of the private serving endpoint
SENSITIVE_SERVE_SECRET=                 # bearer for it
