# Company Brain — Environment Variables
# Copy to .env and fill in. Never commit .env to git.

# ── Supabase (WorkDaemon main app DB) ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=                    # write scope — for per-company private adapter repos
HF_ORG=workdaemon

# ── Model (Hermes-3 — agentic + tool-calling native) ─────────────────────────
BASE_MODEL=unsloth/Hermes-3-Llama-3.1-8B-bnb-4bit

# ── Training ──────────────────────────────────────────────────────────────────
MIN_EXAMPLES_TO_TRAIN=50
TRAINING_WINDOW_HOURS=48

# ── Modal ─────────────────────────────────────────────────────────────────────
MODAL_ENVIRONMENT=main

# ── Serving ───────────────────────────────────────────────────────────────────
SERVE_BACKEND=ollama
WARM_POOL_BUSINESS_HOURS=true
OLLAMA_BASE_URL=http://localhost:11434
# Master secret for the serving API. Per-company bearer tokens are
# HMAC-SHA256(SERVE_MASTER_SECRET, company_id) — the WorkDaemon app stores each
# company's token as its provider api_key. The master also gates admin routes.
# Leave empty to disable serve auth (dev only). Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SERVE_MASTER_SECRET=

# ── Fallback + gate judge ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# ── Vector store + cache ──────────────────────────────────────────────────────
POSTGRES_URL=postgresql://brain:brainpass@localhost:5432/company_brain
REDIS_URL=redis://localhost:6379
VECTOR_BACKEND=pgvector

# ── Scheduling ────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Tool integrations (per company; encrypt at rest in production) ─────────────
SLACK_BOT_TOKEN=xoxb-
NOTION_TOKEN=secret_
GOOGLE_SERVICE_ACCOUNT_KEY=./keys/google.json
HUBSPOT_ACCESS_TOKEN=
QUICKBOOKS_ACCESS_TOKEN=
QUICKBOOKS_REALM_ID=

# ── Security ──────────────────────────────────────────────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=
