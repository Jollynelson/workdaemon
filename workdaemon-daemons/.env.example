
# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Redis (cross-Daemon bus + personal memory)
REDIS_URL=redis://localhost:6379

# Notion
NOTION_API_KEY=secret_your_notion_key
NOTION_TASKS_DB_ID=your_notion_database_id   # The database where tasks live
NOTION_MCP_URL=                               # Leave blank — use direct API

# MCP Mode (set to 'true' in production with OpenClaw runtime)
USE_MCP=false

# Google Calendar + Gmail (handled via MCP — already connected)
# No extra config needed if using the connected MCP servers
