# ─── WorkDaemon Brain — Environment Config ───────────────────────────────────

# Company Identity
COMPANY_ID=acme-corp                        # Unique slug per company
COMPANY_NAME="Acme Corp"                    # Human readable name

# Qdrant (self-hosted vector store)
QDRANT_URL=http://localhost:6333            # Qdrant REST API
QDRANT_API_KEY=                             # Optional — set if auth enabled

# Ollama (self-hosted embedding model)
OLLAMA_URL=http://localhost:11434           # Ollama API
OLLAMA_EMBED_MODEL=nomic-embed-text        # Embedding model

# Groq (Llama 3.1 70B — free tier for simple queries)
GROQ_API_KEY=your_groq_api_key_here        # Get at console.groq.com

# Anthropic (Claude Sonnet — complex reasoning, customer BYOK on paid tier)
ANTHROPIC_API_KEY=your_anthropic_key_here  # Customer's own key on paid tier

# Google Drive (OAuth2 Service Account)
GDRIVE_CLIENT_EMAIL=your-sa@project.iam.gserviceaccount.com
GDRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GDRIVE_DRIVE_ID=                           # Shared drive ID (leave blank for My Drive)

# Postgres (knowledge graph + state)
DATABASE_URL=postgresql://workdaemon:password@localhost:5432/workdaemon

# Brain Settings
CHUNK_SIZE=400                             # Target tokens per chunk
CHUNK_OVERLAP=64                           # Overlap between chunks
TOP_K_RESULTS=8                            # Chunks retrieved per query
CACHE_TTL_SECONDS=1800                     # Cache answers for 30 minutes
COMPLEX_QUERY_THRESHOLD=150                # Chars above this → Claude Sonnet
INGEST_POLL_INTERVAL_MS=900000            # 15 minutes polling interval
