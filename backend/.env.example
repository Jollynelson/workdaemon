# WorkDaemon backend — FINAL build spec (Section 17)

# ── BRAIN (DeepSeek V4, two tiers) ─────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
BRAIN_DEEP_MODEL=deepseek-v4-pro
BRAIN_FAST_MODEL=deepseek-v4-flash
# WARNING: do NOT use deepseek-chat / deepseek-reasoner (retired 2026-07-24).
# VERIFY these model IDs + pricing against DeepSeek's live API before production.
BRAIN_DEEP_REASONING_EFFORT=max
BRAIN_TECHNICAL_REASONING_EFFORT=high
BRAIN_ESCALATION_CONFIDENCE_THRESHOLD=0.6
BRAIN_TECHNICAL_FILE_THRESHOLD=3

# ── HERMES / AGENTS (real Hermes Agent product, one profile per staff) ─────────
HERMES_PORT_RANGE_START=8700      # 8700-8999 per company VPS
HERMES_ENCRYPTION_KEY=            # encrypts per-staff API keys at rest

# ── DATA ───────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://localhost:5432/workdaemon
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
REDIS_URL=redis://localhost:6379
VECTOR_BACKEND=pgvector

# ── EMBEDDINGS (RAG retrieval; DeepSeek has no embeddings endpoint) ──────────────
# Default: free, in-process, no API key, no extra bill.
EMBEDDING_PROVIDER=local                       # local | openai
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# Only needed if EMBEDDING_PROVIDER=openai:
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── KNOWLEDGE GRAPH ──────────────────────────────────────────────────────────────
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── TOOL OAUTH APPS (YOURS — one set, global; NOT access to anyone's data) ───────
# Register WorkDaemon as an app with each provider; these let it ASK each company
# for access. Each company then connects its OWN workspace and we store THEIR token
# encrypted per company. You add these once.
#   Notion:  https://www.notion.so/my-integrations  (public OAuth integration)
#   Slack:   https://api.slack.com/apps  (create app → OAuth & Permissions)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=https://nelsonanyanime--workdaemon-backend-fastapi-app.modal.run

# ── LIVE WEB LEARNING ────────────────────────────────────────────────────────────
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# ── OBSERVABILITY ────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=workdaemon-brain

# ── SCHEDULING ───────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── OPTIONAL GATEWAYS ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TWILIO_ACCOUNT_SID=

# ── SECURITY ─────────────────────────────────────────────────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=
